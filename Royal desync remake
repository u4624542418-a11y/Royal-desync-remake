-- LOGIQUE
local enabled=true
local animConnection

local function stopAnims(hum)
    for _,track in pairs(hum:GetPlayingAnimationTracks()) do track:Stop() end
end

local function setOn(state)
    if state then
        TweenService:Create(knob,TweenInfo.new(0.2,Enum.EasingStyle.Back),{Position=UDim2.new(1,-20,0.5,-9)}):Play()
        TweenService:Create(pill,TweenInfo.new(0.15),{BackgroundColor3=AC1}):Play()
        TweenService:Create(Dot,TweenInfo.new(0.2),{BackgroundColor3=GN}):Play()
        TweenService:Create(mainStroke,TweenInfo.new(0.2),{Color=GN}):Play()
        StatusText.Text="Hook actif - packets interceptes"
        humanoid=getHumanoid()
        stopAnims(humanoid)
        animConnection=humanoid.AnimationPlayed:Connect(function(t) t:Stop() end)
        pcall(function() raknet.desync(true) end)
    else
        TweenService:Create(knob,TweenInfo.new(0.2,Enum.EasingStyle.Back),{Position=UDim2.new(0,2,0.5,-9)}):Play()
        TweenService:Create(pill,TweenInfo.new(0.15),{BackgroundColor3=BT}):Play()
        TweenService:Create(Dot,TweenInfo.new(0.2),{BackgroundColor3=RD}):Play()
        TweenService:Create(mainStroke,TweenInfo.new(0.2),{Color=AC1}):Play()
        StatusText.Text="Desync inactive - no interception"
        if animConnection then animConnection:Disconnect(); animConnection=nil end
        pcall(function() raknet.desync(false) end)
    end
end

ToggleButton.Activated:Connect(function()
