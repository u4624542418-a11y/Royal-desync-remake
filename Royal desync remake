local function mkCorner(p,r) local c=Instance.new("UICorner",p) c.CornerRadius=UDim.new(0,r or 8) end
local function mkStroke(p,col,th)
    local s=Instance.new("UIStroke",p)
    s.Color=col or AC1 s.Thickness=th or 1.5
    s.ApplyStrokeMode=Enum.ApplyStrokeMode.Border
    return s
end

